<UserControl x:Class="Hercules.Views.NodeControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="140" Height="90">
    <Border Background="#333" BorderBrush="#0078D4" BorderThickness="1" CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Background="#444" Padding="8" CornerRadius="8,8,0,0">
                <TextBlock Text="{Binding Title}" Foreground="White" FontWeight="Bold"/>
            </Border>

            <StackPanel Grid.Row="1" Margin="10">
                <TextBlock Text="Logic Node" Foreground="#888" FontSize="10"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
